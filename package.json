{
  "name": "ai-sdr-system",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Autonomous-but-controlled AI SDR/BDR outbound system: leads, multi-touch campaigns, AI personalization, tracking, scoring, notifications, and a daily learning loop.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "tracking-server": "tsx src/server/tracking-server.ts",
    "cli": "tsx src/cli/index.ts",
    "dispatch": "tsx src/cli/index.ts dispatch",
    "process-events": "tsx src/cli/index.ts process-events",
    "daily-cycle": "tsx src/cli/index.ts daily-cycle",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "mongodb": "^6.12.0",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.9.16",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
