# ───────────────────────────────────────────────────────────────────────────
# AI SDR/BDR System — environment configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ───────────────────────────────────────────────────────────────────────────

# ── Database ────────────────────────────────────────────────────────────────
# Use a NEW rotated password. Your old credentials were committed to a public
# repo and must be considered compromised — rotate them in MongoDB Atlas.
MONGODB_URI=""
MONGODB_DB="email_db"

# ── LLM: worker role (high-volume writing/classification) ───────────────────
# "GPT-5.4 mini" — set the model to whatever your provider actually exposes.
# The adapter is OpenAI-compatible, so any OpenAI-compatible endpoint works.
WORKER_BASE_URL="https://api.openai.com/v1"
WORKER_API_KEY=""
WORKER_MODEL="gpt-5.4-mini"

# ── LLM: strategist role (daily/weekly analysis, experiment planning) ───────
# "GLM-5.2 max". GLM (Zhipu) is OpenAI-compatible.
#   China endpoint:        https://open.bigmodel.cn/api/paas/v4
#   International (z.ai):   https://api.z.ai/api/paas/v4
STRATEGIST_BASE_URL="https://open.bigmodel.cn/api/paas/v4"
STRATEGIST_API_KEY=""
STRATEGIST_MODEL="glm-5.2-max"

# ── Email sending (SMTP) ────────────────────────────────────────────────────
# Works with Google Workspace, Zoho, Mailgun SMTP, etc.
# For Gmail: use an App Password (requires 2FA), host smtp.gmail.com port 465.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER=""
SMTP_PASS=""
# The visible From. SMTP_USER often must match or be an alias of this.
FROM_NAME=""
FROM_EMAIL=""
# Where replies should go (defaults to FROM_EMAIL).
REPLY_TO_EMAIL=""

# Safety throttles so you don't torch your domain reputation.
DAILY_SEND_LIMIT="40"
MAX_SENDS_PER_RUN="20"
MIN_SECONDS_BETWEEN_SENDS="45"
# Dry run = build + log emails but DON'T actually send. Start with this true.
DRY_RUN="true"

# ── Mailbox rotation pool (optional) ────────────────────────────────────────
# To send volume without burning one domain, spread sends across several
# mailboxes. Each prospect gets ONE sticky mailbox for their whole thread.
# Leave MAILBOXES empty to use the single SMTP_* mailbox above (back-compatible).
#
# JSON array; per mailbox only "email" + creds are required, the rest default
# to the SMTP_*/FROM_* values above. Or set MAILBOXES_FILE to a path instead.
# Fields: email, fromName?, replyTo?, host?, port?, secure?, user?, pass?,
#         dailyCap?, warmup?
# MAILBOXES='[{"email":"sales1@you.com","user":"sales1@you.com","pass":"app-pw-1"},{"email":"sales2@you.com","user":"sales2@you.com","pass":"app-pw-2"}]'
# MAILBOXES_FILE="./mailboxes.json"

# Per-mailbox ceiling once fully warmed (per-mailbox "dailyCap" overrides this).
MAILBOX_DAILY_CAP="40"
# Warmup ramp: each mailbox starts at WARMUP_START_PER_DAY emails/day and adds
# WARMUP_INCREMENT_PER_DAY each day since its first send, capped at WARMUP_MAX_PER_DAY.
WARMUP_ENABLED="true"
WARMUP_START_PER_DAY="5"
WARMUP_INCREMENT_PER_DAY="5"
WARMUP_MAX_PER_DAY="40"

# ── Tracking server ─────────────────────────────────────────────────────────
# Public base URL where this project's tracking server is reachable.
# Opens/clicks only work if prospects can reach this from the internet.
# You can keep using your existing Cloud Run pixel host here instead.
TRACKING_BASE_URL="http://localhost:8787"
TRACKING_PORT="8787"
# Shared secret for the inbound-reply webhook (Instantly/SES/Mailgun -> us).
REPLY_WEBHOOK_SECRET="change-me"

# ── Inbound replies via IMAP (optional) ─────────────────────────────────────
# If you DON'T have a provider POSTing to /webhook/reply, turn this on to poll
# your sending mailboxes over IMAP and auto-capture replies. Auth reuses each
# mailbox's SMTP user/pass (or SMTP_USER/SMTP_PASS for the single mailbox).
# Per-mailbox overrides: add "imapHost"/"imapPort"/"imapSecure" to a MAILBOXES entry.
IMAP_ENABLED="false"
IMAP_HOST="imap.gmail.com"
IMAP_PORT="993"
IMAP_SECURE="true"
# On a mailbox's first poll, only ingest mail from the last N days.
IMAP_LOOKBACK_DAYS="14"

# ── Sending window (prospect-friendly hours, system local time) ─────────────
SEND_WINDOW_START_HOUR="8"
SEND_WINDOW_END_HOUR="17"
SEND_ON_WEEKENDS="false"

# ── Notifications ───────────────────────────────────────────────────────────
# Generic incoming-webhook URL (Slack or Discord both accept JSON {text/content}).
NOTIFY_WEBHOOK_URL=""
# Optional: also email yourself important alerts.
NOTIFY_EMAIL=""

# ── Compliance (required for cold/commercial email) ─────────────────────────
COMPANY_NAME="Your Company LLC"
COMPANY_ADDRESS="123 Main St, City, ST 00000"
UNSUBSCRIBE_FOOTER="true"
# A List-Unsubscribe + one-click (RFC 8058) header is added to every send
# automatically (Gmail/Yahoo require it for bulk senders) — no config needed.

# Reputation guard: auto-pause ALL sending if the recent bounce rate spikes.
# Resumes automatically once the rate drops back below the threshold.
BOUNCE_PAUSE_THRESHOLD_PCT="8"
BOUNCE_PAUSE_MIN_SAMPLE="20"
BOUNCE_WINDOW_HOURS="24"

# ── Agent brain (autonomy) ──────────────────────────────────────────────────
# semi   = low-risk actions auto-run; high-risk (new offers, launching, sourcing)
#          require your approval in Telegram.
# propose = the agent proposes everything and waits for approval.
# full    = the agent acts within hard caps (no approval). Highest risk.
AGENT_AUTONOMY="semi"
AGENT_MAX_STEPS="8"
AGENT_MAX_LEADS_PER_SOURCE="25"

# ── Telegram chat + approvals ───────────────────────────────────────────────
# Create a bot with @BotFather → token. Get your chat id from @userinfobot.
# TELEGRAM_CHAT_ID is the default owner chat for startup messages/notifications.
# TELEGRAM_ALLOWED_USER_IDS lets trusted users talk to the bot from private chats
# or groups. Use Telegram numeric user IDs, comma-separated.
# TELEGRAM_ALLOWED_CHAT_IDS lets everyone in specific chats/groups talk to it.
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
TELEGRAM_ALLOWED_USER_IDS=""
TELEGRAM_ALLOWED_CHAT_IDS=""

# ── Web search (lead research + free lead discovery) ────────────────────────
# provider:
#   "duckduckgo" — FREE, no key (we parse DDG's HTML). Default. Can rate-limit.
#   "searxng"    — FREE, self-hosted metasearch (most robust). Set SEARXNG_URL.
#                  Run one:  docker run -d -p 8080:8080 searxng/searxng
#                  then enable the JSON format in its settings.yml.
#   "serper"     — paid (serper.dev), most reliable. Needs SEARCH_API_KEY.
#   "tavily"     — paid (tavily.com). Needs SEARCH_API_KEY.
SEARCH_PROVIDER="duckduckgo"
SEARCH_API_KEY=""
SEARXNG_URL=""

# ── Free lead discovery (search → email pattern → verify; no Apollo needed) ──
# SMTP-probe verification uses port 25. Many home ISPs block it — then we fall
# back to "guessed" emails and let bounces filter them out.
DISCOVERY_SMTP_PROBE="true"
DISCOVERY_IMPORT_GUESSED="true"

# ── Apollo.io lead sourcing (OPTIONAL, PAID — needs an API plan) ─────────────
# Leave blank if you have no Apollo API plan; use discover_leads instead.
APOLLO_API_KEY=""

# ── Apify lead sourcing (OPTIONAL, PAID actor runs) ─────────────────────────
# Actor id can be "username/actor-name" or the Apify actor id.
APIFY_API_TOKEN=""
APIFY_LEADS_ACTOR_ID="peakydev/leads-scraper-ppe"
APIFY_MAX_RESULTS_PER_RUN="30000"
APIFY_MAX_COST_PER_RUN_USD="30"
APIFY_POLL_SECONDS="10"

# ── Gemini TTS (video voiceover) ────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=""
GEMINI_TTS_MODEL="gemini-2.5-flash-preview-tts"
GEMINI_TTS_VOICE="Kore"

# ── Video rendering (Remotion) ──────────────────────────────────────────────
# Run `cd remotion && npm install` once, then flip this to true.
VIDEO_ENABLE_REMOTION="false"
VIDEO_OUTPUT_DIR="data/videos"
